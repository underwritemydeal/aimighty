# AImighty Environment Variables
# Copy this file to .env.local and fill in your values

# Cloudflare Worker URL
# After deploying your worker with `wrangler deploy`, you'll get a URL like:
# https://aimighty-api.YOUR_SUBDOMAIN.workers.dev
# Set that URL here:
VITE_WORKER_URL=https://aimighty-api.YOUR_SUBDOMAIN.workers.dev
